# ==========================================================
# .env.example
# Copy file này thành ".env" rồi điền giá trị thật.
# KHÔNG commit file ".env" (chứa key thật) lên git/chia sẻ công khai.
# ==========================================================

# ----------------------------------------------------------
# AWS Credentials (bắt buộc nếu USE_BEDROCK=true)
# Có thể bỏ trống nếu đã cấu hình qua `aws configure` (dùng
# ~/.aws/credentials) - khi đó boto3 tự đọc, không cần khai ở đây.
# ----------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ----------------------------------------------------------
# Cấu hình Bedrock
# ----------------------------------------------------------
USE_BEDROCK=True
BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0
BEDROCK_REGION=ap-northeast-1

# ----------------------------------------------------------
# HuggingFace (tuỳ chọn - chỉ cần nếu tải model gated/private)
# ----------------------------------------------------------
HF_TOKEN=
